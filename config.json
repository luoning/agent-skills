{
  "name": "custom-agent-skills",
  "version": "1.0.0",
  "description": "Production-grade engineering skills for AI coding agents.",
  "engines": {
    "gemini": ">=2.0",
    "claude": ">=3.5"
  },
  "modules": [
    "skills/web-autobuild",
    "skills/web-design",
    "skills/architecture-piercing",
    "skills/skill-governance"
  ],
  "routing_rules": {
    "workflow-contract": {
      "path": "skills/skill-governance/sub-skills/workflow-contract.md",
      "dependencies": []
    },
    "url-extractor": {
      "path": "skills/skill-governance/sub-skills/url-extractor.md",
      "dependencies": ["workflow-contract"]
    },
    "static-auditor": {
      "path": "skills/skill-governance/sub-skills/static-auditor.md",
      "dependencies": ["workflow-contract"]
    },
    "scenario-tester": {
      "path": "skills/skill-governance/sub-skills/scenario-tester.md",
      "dependencies": ["static-auditor"]
    },
    "web-design": {
      "path": "skills/web-design/SKILL.md",
      "dependencies": ["workflow-contract"]
    },
    "web-autobuild": {
      "path": "skills/web-autobuild/SKILL.md",
      "dependencies": ["web-design", "workflow-contract"]
    }
  }
}
